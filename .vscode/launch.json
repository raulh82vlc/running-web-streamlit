{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Streamlit: ejecutar app",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": ["run", "streamlit_app.py", "--server.runOnSave=false"],
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONPATH": "${workspaceFolder}"},
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
